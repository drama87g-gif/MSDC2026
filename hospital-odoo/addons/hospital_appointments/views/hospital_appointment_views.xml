<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="hospital_appointment_view_tree" model="ir.ui.view">
            <field name="name">hospital.appointment.view.tree</field>
            <field name="model">hospital.appointment</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="name"/>
                    <field name="patient_id"/>
                    <field name="doctor_id"/>
                    <field name="appointment_date"/>
                    <field name="state"/>
                    <field name="consultation_fee"/>
                </tree>
            </field>
        </record>

        <record id="hospital_appointment_view_form" model="ir.ui.view">
            <field name="name">hospital.appointment.view.form</field>
            <field name="model">hospital.appointment</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <button name="action_start_appointment" string="Start" type="object"/>
                        <button name="action_complete_appointment" string="Complete" type="object"/>
                        <button name="action_cancel_appointment" string="Cancel" type="object"/>
                        <field name="state" widget="statusbar"/>
                    </header>
                    <sheet>
                        <group>
                            <group>
                                <field name="name" readonly="True"/>
                                <field name="patient_id"/>
                                <field name="doctor_id"/>
                                <field name="department_id"/>
                            </group>
                            <group>
                                <field name="appointment_date"/>
                                <field name="duration"/>
                                <field name="consultation_fee" readonly="True"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Symptoms">
                                <field name="symptoms" widget="html"/>
                            </page>
                            <page string="Notes">
                                <field name="notes" widget="html"/>
                            </page>
                        </notebook>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_ids"/>
                    </div>
                </form>
            </field>
        </record>

        <record id="hospital_appointment_view_search" model="ir.ui.view">
            <field name="name">hospital.appointment.view.search</field>
            <field name="model">hospital.appointment</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name"/>
                    <field name="patient_id"/>
                    <field name="doctor_id"/>
                    <filter name="scheduled" string="Scheduled" domain="[('state', '=', 'scheduled')]"/>
                    <filter name="completed" string="Completed" domain="[('state', '=', 'completed')]"/>
                    <separator/>
                    <group expand="1" string="Group By">
                        <filter name="group_by_doctor" string="Doctor" context="{'group_by': 'doctor_id'}"/>
                        <filter name="group_by_patient" string="Patient" context="{'group_by': 'patient_id'}"/>
                        <filter name="group_by_state" string="Status" context="{'group_by': 'state'}"/>
                    </group>
                </search>
            </field>
        </record>

        <record id="hospital_appointment_action" model="ir.actions.act_window">
            <field name="name">Appointments</field>
            <field name="res_model">hospital.appointment</field>
            <field name="view_mode">tree,form</field>
        </record>
    </data>
</odoo>
