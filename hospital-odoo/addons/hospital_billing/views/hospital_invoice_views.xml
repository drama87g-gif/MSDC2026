<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="hospital_invoice_view_tree" model="ir.ui.view">
            <field name="name">hospital.invoice.view.tree</field>
            <field name="model">hospital.invoice</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="name"/>
                    <field name="patient_id"/>
                    <field name="invoice_date"/>
                    <field name="total_due"/>
                    <field name="paid_amount"/>
                    <field name="balance"/>
                    <field name="state"/>
                </tree>
            </field>
        </record>

        <record id="hospital_invoice_view_form" model="ir.ui.view">
            <field name="name">hospital.invoice.view.form</field>
            <field name="model">hospital.invoice</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <button name="action_issue" string="Issue" type="object"/>
                        <button name="action_cancel" string="Cancel" type="object"/>
                        <field name="state" widget="statusbar"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1><field name="name" readonly="True"/></h1>
                        </div>
                        <group>
                            <group>
                                <field name="patient_id"/>
                                <field name="appointment_id"/>
                                <field name="doctor_id"/>
                                <field name="invoice_date"/>
                            </group>
                            <group>
                                <field name="due_date"/>
                                <field name="payment_method"/>
                            </group>
                        </group>
                        <field name="invoice_line_ids">
                            <tree editable="bottom">
                                <field name="line_type"/>
                                <field name="description"/>
                                <field name="quantity"/>
                                <field name="unit_price"/>
                                <field name="amount"/>
                            </tree>
                        </field>
                        <group class="oe_subtotal_footer oe_right" colspan="2">
                            <div class="oe_subtotal_footer_separator"/>
                            <field name="total_services" widget="monetary"/>
                            <field name="total_medicines" widget="monetary"/>
                            <div class="oe_subtotal_footer_separator"/>
                            <field name="total_charges" widget="monetary" class="oe_subtotal_footer_separator"/>
                            <field name="discount" string="Discount (%)"/>
                            <field name="discount_amount" widget="monetary"/>
                            <field name="tax_amount" widget="monetary"/>
                            <field name="total_due" widget="monetary" class="oe_highlight"/>
                        </group>
                        <group>
                            <field name="paid_amount" widget="monetary"/>
                            <field name="balance" widget="balance" readonly="True"/>
                        </group>
                        <group>
                            <field name="notes" widget="html"/>
                            <field name="terms" widget="html"/>
                        </group>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_ids"/>
                    </div>
                </form>
            </field>
        </record>

        <record id="hospital_invoice_view_search" model="ir.ui.view">
            <field name="name">hospital.invoice.view.search</field>
            <field name="model">hospital.invoice</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name"/>
                    <field name="patient_id"/>
                    <filter name="issued" string="Issued" domain="[('state', '=', 'issued')]"/>
                    <filter name="unpaid" string="Unpaid" domain="[('balance', '&gt;', 0)]"/>
                    <filter name="paid" string="Paid" domain="[('state', '=', 'paid')]"/>
                    <separator/>
                    <group expand="1" string="Group By">
                        <filter name="group_by_patient" string="Patient" context="{'group_by': 'patient_id'}"/>
                        <filter name="group_by_state" string="Status" context="{'group_by': 'state'}"/>
                        <filter name="group_by_date" string="Invoice Date" context="{'group_by': 'invoice_date'}"/>
                    </group>
                </search>
            </field>
        </record>

        <record id="hospital_invoice_action" model="ir.actions.act_window">
            <field name="name">Invoices</field>
            <field name="res_model">hospital.invoice</field>
            <field name="view_mode">tree,form</field>
        </record>
    </data>
</odoo>
