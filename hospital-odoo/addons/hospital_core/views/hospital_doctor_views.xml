<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="hospital_doctor_view_tree" model="ir.ui.view">
            <field name="name">hospital.doctor.view.tree</field>
            <field name="model">hospital.doctor</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="name"/>
                    <field name="specialization"/>
                    <field name="department_id"/>
                    <field name="phone"/>
                    <field name="consultation_fee"/>
                    <field name="state"/>
                </tree>
            </field>
        </record>

        <record id="hospital_doctor_view_form" model="ir.ui.view">
            <field name="name">hospital.doctor.view.form</field>
            <field name="model">hospital.doctor</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <field name="state" widget="statusbar" options="{'clickable': True}"/>
                    </header>
                    <sheet>
                        <group>
                            <group>
                                <field name="name"/>
                                <field name="email"/>
                                <field name="phone"/>
                                <field name="specialization"/>
                                <field name="department_id"/>
                            </group>
                            <group>
                                <field name="license_number"/>
                                <field name="experience_years"/>
                                <field name="consultation_fee"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Qualifications">
                                <field name="qualification" widget="html"/>
                            </page>
                            <page string="Availability">
                                <field name="available_days" widget="many2many_tags"/>
                            </page>
                        </notebook>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_ids"/>
                    </div>
                </form>
            </field>
        </record>

        <record id="hospital_doctor_view_search" model="ir.ui.view">
            <field name="name">hospital.doctor.view.search</field>
            <field name="model">hospital.doctor</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name" string="Doctor Name"/>
                    <field name="specialization"/>
                    <field name="department_id"/>
                    <filter name="available" string="Available" domain="[('state', '=', 'available')]"/>
                    <separator/>
                    <group expand="1" string="Group By">
                        <filter name="group_by_dept" string="Department" context="{'group_by': 'department_id'}"/>
                        <filter name="group_by_spec" string="Specialization" context="{'group_by': 'specialization'}"/>
                        <filter name="group_by_state" string="Status" context="{'group_by': 'state'}"/>
                    </group>
                </search>
            </field>
        </record>

        <record id="hospital_doctor_action" model="ir.actions.act_window">
            <field name="name">Doctors</field>
            <field name="res_model">hospital.doctor</field>
            <field name="view_mode">tree,form</field>
        </record>
    </data>
</odoo>
